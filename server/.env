# Example configuration.
# Copy this to a new file named .env.local and fill in the values.

# Set to true to enable browsing the local filesystem directly.
# When false, the server will connect to the sqlite catalog.db.
BROWSE_LOCAL_FILESYSTEM=false

# The path to your music catalog root.
LOCAL_CATALOG_ROOT='/my/music/catalog'

# The path to your soundfont files.
LOCAL_SOUNDFONT_ROOT='/my/soundfonts'

# The path to your client build files.
LOCAL_CLIENT_BUILD_ROOT='/var/www/my-domain/public_html'
